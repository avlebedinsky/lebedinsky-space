{
  "name": "lebedinsky-space",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "cd apps/api && go run .",
    "build:web": "npm run build -w apps/web",
    "lint:web": "npm run lint -w apps/web",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && npx eslint --max-warnings=0 \"${@#apps/web/}\"' --",
      "bash -c 'cd apps/web && npx tsc --noEmit'"
    ]
  }
}
